{
  "productName": "addon",
  "version": "0.1.0",
  "identifier": "com.dgspark.addon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "systemTray": {
    "iconPath": "icons/tray.png",
    "iconAsTemplate": true
  }
}
