{
  "productName": "addon",
  "version": "0.1.0",
  "identifier": "com.dgspark.addon",
  "build": {
    "frontendDist": "..",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "addon \u2014 Key Shortcut Sync",
        "width": 900,
        "height": 650,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "systemTray": {
    "iconPath": "icons/tray.png",
    "iconAsTemplate": true
  }
}
