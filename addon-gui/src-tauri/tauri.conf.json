{
  "productName": "addon",
  "version": "0.1.0",
  "identifier": "com.dgspark.addon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "addon — Key Shortcut Sync",
        "width": 900,
        "height": 650,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": [] },
  "systemTray": { "iconPath": "icons/tray.png", "iconAsTemplate": true }
}
